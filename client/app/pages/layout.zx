pub fn Layout(ctx: zx.LayoutContext, children: zx.Component) zx.Component {
    return (
        <html @allocator={ctx.arena} lang="en">
            <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                <meta name="color-scheme" content="dark" />
                <meta name="description" content="A self-hosted frontend for local and API-driven LLM roleplay and chat." />
                <title>SillyTavern</title>
                <link rel="icon" type="image/png" href="/glue/favicon.png" />
                <link rel="preload" as="font" type="font/woff2" href="/glue/fonts/Newsreader-latin.woff2" crossorigin />
                <link rel="stylesheet" href="/glue/vendor/hljs-theme.css" />
                <link rel="stylesheet" href="/glue/app.css" />
            </head>

            <body>
                <a class="skip-link" href="#send_textarea">Skip to message input</a>
                {children}
            </body>
        </html>
    );
}

const zx = @import("zx");
