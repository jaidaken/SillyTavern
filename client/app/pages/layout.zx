// The document shell. The body carries the app's ground, its reading face and the safe-area insets
// (an iPhone notch eats the left and right edges); the skip link sits off-screen until it is focused
// and then anchors over the top bar (WD36/WD37).
pub fn Layout(ctx: zx.LayoutContext, children: zx.Component) zx.Component {
    return (
        <html @allocator={ctx.arena} lang="en" class="h-full scheme-dark">
            <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                <meta name="color-scheme" content="dark" />
                <meta name="description" content="A self-hosted frontend for local and API-driven LLM roleplay and chat." />
                <title>SillyTavern</title>
                <link rel="icon" type="image/png" href="/glue/favicon.png" />
                <link rel="preload" as="font" type="font/woff2" href="/glue/fonts/Newsreader-latin.woff2" crossorigin />
                <link rel="preload" as="font" type="font/woff2" href="/glue/fonts/Newsreader-latin-italic.woff2" crossorigin />
                <link rel="preload" as="font" type="font/woff2" href="/glue/fonts/JetBrainsMono-latin.woff2" crossorigin />
                <link rel="preload" as="font" type="font/woff2" href="/glue/fonts/JetBrainsMono-latin-italic.woff2" crossorigin />
                <link rel="stylesheet" href="/glue/vendor/hljs-theme.css" />
                <link rel="stylesheet" href="/glue/app.css" />
            </head>

            <body class="h-full bg-bg pl-[env(safe-area-inset-left)] font-serif text-base leading-ui text-text antialiased [text-rendering:optimizeLegibility] pr-[env(safe-area-inset-right)] max-[640px]:text-[0.92rem]">
                <a
                    class="absolute -top-12 left-2 z-40 rounded-md border border-border bg-surface-2 px-3 py-2 text-text no-underline transition-[top] duration-120 ease-[ease] focus:top-2"
                    href="#send_textarea"
                >Skip to message input</a>
                {children}
            </body>
        </html>
    );
}

const zx = @import("zx");
