// World Info panel body. Top-bar drawer.
pub fn WorldInfoBody(allocator: zx.Allocator) zx.Component {
    // A bare component root transpiles to ziex's failing-allocator context; allocInit mounts it with the real one.
    var zctx = zx.x.allocInit(allocator);
    return zctx.cmp(PanelEmpty, .{ .name = "PanelEmpty" }, .{});
}

const zx = @import("zx");
const PanelEmpty = @import("../panelchrome.zx").PanelEmpty;
