diff --git i/src/runtime/core/vdom.zig w/src/runtime/core/vdom.zig
index 119f44a4..3cd8cb7e 100644
--- i/src/runtime/core/vdom.zig
+++ w/src/runtime/core/vdom.zig
@@ -108,6 +108,35 @@ pub const VNode = struct {
         return self;
     }
 
+    fn childIndexOf(self: *const VNode, id: u64) ?usize {
+        for (self.children.items, 0..) |child, i| {
+            if (child.id == id) return i;
+        }
+        return null;
+    }
+
+    /// Position a child insert takes, derived from the reference node the DOM insert uses.
+    /// A null reference means append, matching appendChild; an unknown reference appends too,
+    /// because insertBefore has already failed by then and the vtree is the surviving record.
+    fn insertIndexFor(self: *const VNode, reference_id: ?u64) usize {
+        const ref_id = reference_id orelse return self.children.items.len;
+        return self.childIndexOf(ref_id) orelse self.children.items.len;
+    }
+
+    /// Insert `child` where `_ib`/`_ac` put its DOM node. Ordering both from the same
+    /// reference_id is what keeps the vtree and the DOM in the same order.
+    pub fn insertChildBefore(self: *VNode, allocator: zx.Allocator, child: *VNode, reference_id: ?u64) !void {
+        try self.children.insert(allocator, self.insertIndexFor(reference_id), child);
+    }
+
+    /// Move an existing child to where `_ib`/`_ac` moved its DOM node. The reference is resolved
+    /// after the removal, since removing shifts every later sibling down one.
+    pub fn moveChildBefore(self: *VNode, allocator: zx.Allocator, vnode_id: u64, reference_id: ?u64) !void {
+        const old_idx = self.childIndexOf(vnode_id) orelse return;
+        const moved = self.children.orderedRemove(old_idx);
+        try self.children.insert(allocator, self.insertIndexFor(reference_id), moved);
+    }
+
