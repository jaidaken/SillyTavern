+/// A component that dirties itself on every render would spin the drain forever; stop and say so
+/// rather than hang the page.
+const max_drain_passes: u32 = 32;
+
+var render_gate: RenderGate = .empty;
+
+/// Render `cmp`, then flush anything its own component functions dirtied while it ran.
+///
+/// The gate is held across the diff AND the apply, so a component function that mutates state
+/// mid-diff cannot start a second pass on the same vtree: it is recorded dirty and rendered here,
+/// against the tree this pass leaves behind. Without that, the nested pass frees vnodes the outer
+/// pass's already-computed list still names (`_rc(0,0)`, a freed vnode read back as zeros).
 pub fn render(self: *Client, cmp: ComponentMeta) !void {
+    if (!try render_gate.tryEnter(self.allocator, cmp.id)) return;
+    defer render_gate.exit();
+
+    const result = self.renderOnce(cmp);
+    self.drainDirty();
+    return result;
+}
+
+fn drainDirty(self: *Client) void {
+    var passes: u32 = 0;
+    while (render_gate.isDirty()) {
+        if (passes >= max_drain_passes) {
+            render_gate.clearDirty();
+            const console = Console.init();
+            defer console.deinit();
+            console.log(.{js.string("[zx:render] ANOMALY drain hit the pass cap; a component dirties itself every render, so its updates are dropped rather than spun on. Not on the [zx:dom] channel: that one is the door glue, and a non-error carrying its prefix reads as a leaked trace")});
+            return;
+        }
+        passes += 1;
+
+        var batch: std.ArrayList([]const u8) = .empty;
+        defer batch.deinit(self.allocator);
+        render_gate.takeDirty(self.allocator, &batch) catch return;
+
+        for (batch.items) |id| {
+            for (self.components) |c| {
+                if (std.mem.eql(u8, c.id, id)) {
+                    self.renderOnce(c) catch {};
+                    break;
+                }
+            }
+        }
+    }
+}
+
+fn renderOnce(self: *Client, cmp: ComponentMeta) !void {
     const allocator = self.allocator;
 
     const document = Document.init(allocator);
