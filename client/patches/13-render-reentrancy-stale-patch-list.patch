diff --git c/src/runtime/core/render_gate.zig w/src/runtime/core/render_gate.zig
new file mode 100644
index 00000000..e75be0de
--- /dev/null
+++ w/src/runtime/core/render_gate.zig
@@ -0,0 +1,53 @@
+//! Serialises render passes so a patch list can never be applied to a tree it was not diffed against.
+
+const std = @import("std");
+
+/// One pass owns the gate from the start of its diff to the end of its apply.
+///
+/// A component function runs during the diff (`resolveComponent` calls it), so it can mutate state
+/// and re-enter `render` for a component whose diff is already in flight. Ungated, that nested pass
+/// diffs and applies the SAME vtree; the outer pass then applies a list describing a tree that no
+/// longer exists, naming vnodes the inner pass freed. Refusing the nested pass BEFORE it can reach a
+/// vtree is what makes the stale list unrepresentable rather than unlikely.
+pub const RenderGate = struct {
+    in_flight: bool = false,
+    dirty: std.StringHashMapUnmanaged(void) = .empty,
+
+    pub const empty: RenderGate = .{};
+
+    pub fn deinit(self: *RenderGate, allocator: std.mem.Allocator) void {
+        self.dirty.deinit(allocator);
+    }
+
+    /// True when the caller owns the pass and may diff. False means the request was deferred: the
+    /// id is recorded dirty and the owning pass will render it once its own apply has finished.
+    /// A caller handed false must not touch a vtree.
+    pub fn tryEnter(self: *RenderGate, allocator: std.mem.Allocator, id: []const u8) !bool {
+        if (self.in_flight) {
+            try self.dirty.put(allocator, id, {});
+            return false;
+        }
+        self.in_flight = true;
+        return true;
+    }
+
+    pub fn exit(self: *RenderGate) void {
+        self.in_flight = false;
+    }
+
+    pub fn isDirty(self: *const RenderGate) bool {
+        return self.dirty.count() > 0;
+    }
+
+    pub fn clearDirty(self: *RenderGate) void {
+        self.dirty.clearRetainingCapacity();
+    }
+
+    /// Move the pending ids out. Anything dirtied while the caller renders them lands in the NEXT
+    /// batch rather than mutating the set being walked.
+    pub fn takeDirty(self: *RenderGate, allocator: std.mem.Allocator, out: *std.ArrayList([]const u8)) !void {
+        var it = self.dirty.keyIterator();
+        while (it.next()) |k| try out.append(allocator, k.*);
+        self.dirty.clearRetainingCapacity();
+    }
+};
