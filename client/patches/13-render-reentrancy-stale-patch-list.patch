diff --git c/test/core/render_gate.zig w/test/core/render_gate.zig
new file mode 100644
index 00000000..2374cd0c
--- /dev/null
+++ w/test/core/render_gate.zig
@@ -0,0 +1,93 @@
+const std = @import("std");
+const zx = @import("zx");
+
+const testing = std.testing;
+const RenderGate = zx.util.render_gate.RenderGate;
+
+test "a pass entered during another is refused, so two diffs cannot share one vtree" {
+    const allocator = testing.allocator;
+    var gate: RenderGate = .empty;
+    defer gate.deinit(allocator);
+
+    try testing.expect(try gate.tryEnter(allocator, "shell"));
+    // The re-entrant call is the one that used to diff and apply the same vtree mid-flight, then
+    // let the outer pass apply a list naming the vnodes it had just freed.
+    try testing.expect(!try gate.tryEnter(allocator, "shell"));
+    try testing.expect(!try gate.tryEnter(allocator, "composer"));
+}
+
+test "a refused pass is recorded dirty rather than dropped" {
+    const allocator = testing.allocator;
+    var gate: RenderGate = .empty;
+    defer gate.deinit(allocator);
+
+    try testing.expect(try gate.tryEnter(allocator, "shell"));
+    try testing.expect(!gate.isDirty());
+
+    try testing.expect(!try gate.tryEnter(allocator, "shell"));
+    try testing.expect(gate.isDirty());
+
+    var batch: std.ArrayList([]const u8) = .empty;
+    defer batch.deinit(allocator);
+    try gate.takeDirty(allocator, &batch);
+    try testing.expectEqual(@as(usize, 1), batch.items.len);
+    try testing.expectEqualStrings("shell", batch.items[0]);
+}
+
+test "an id dirtied repeatedly drains once" {
+    const allocator = testing.allocator;
+    var gate: RenderGate = .empty;
+    defer gate.deinit(allocator);
+
+    try testing.expect(try gate.tryEnter(allocator, "shell"));
+    try testing.expect(!try gate.tryEnter(allocator, "shell"));
+    try testing.expect(!try gate.tryEnter(allocator, "shell"));
+
+    var batch: std.ArrayList([]const u8) = .empty;
+    defer batch.deinit(allocator);
+    try gate.takeDirty(allocator, &batch);
+    try testing.expectEqual(@as(usize, 1), batch.items.len);
+}
+
+test "taking the dirty set empties it, so the drain loop can reach an exit condition" {
+    const allocator = testing.allocator;
+    var gate: RenderGate = .empty;
+    defer gate.deinit(allocator);
+
+    try testing.expect(try gate.tryEnter(allocator, "shell"));
+    try testing.expect(!try gate.tryEnter(allocator, "shell"));
+
+    var batch: std.ArrayList([]const u8) = .empty;
+    defer batch.deinit(allocator);
+    try gate.takeDirty(allocator, &batch);
+    try testing.expect(!gate.isDirty());
+}
+
+test "exit hands the gate to the next pass" {
+    const allocator = testing.allocator;
+    var gate: RenderGate = .empty;
+    defer gate.deinit(allocator);
+
+    try testing.expect(try gate.tryEnter(allocator, "shell"));
+    gate.exit();
+    // The next top-level render owns the gate outright and diffs a tree nothing else is touching.
+    try testing.expect(try gate.tryEnter(allocator, "shell"));
+    try testing.expect(!gate.isDirty());
+}
+
+fn enterRefuseAndDrain(allocator: std.mem.Allocator) !void {
+    var gate: RenderGate = .empty;
+    defer gate.deinit(allocator);
+
+    _ = try gate.tryEnter(allocator, "shell");
+    _ = try gate.tryEnter(allocator, "shell");
+    _ = try gate.tryEnter(allocator, "composer");
+
+    var batch: std.ArrayList([]const u8) = .empty;
+    defer batch.deinit(allocator);
+    try gate.takeDirty(allocator, &batch);
+}
+
+test "the gate leaks nothing on any allocation failure" {
+    try testing.checkAllAllocationFailures(testing.allocator, enterRefuseAndDrain, .{});
+}
