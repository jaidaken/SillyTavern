+/// The reconcile-memo signal of an unresolved child, or 0 when it is not a memoizable component.
+fn memoOf(component: zx.Component) u64 {
+    return switch (component) {
+        .component_fn => |comp_fn| comp_fn.memo,
+        else => 0,
+    };
+}
+
+/// Build a vnode from an already-resolved child while preserving the memo signal and key from its
+/// unresolved form, which resolution would otherwise drop (the resolved element carries neither).
+fn createMemoizedChild(allocator: zx.Allocator, resolved: zx.Component, unresolved: zx.Component, owner_component_id: []const u8) anyerror!*VNode {
+    const node = try VNode.createFromComponent(allocator, resolved, owner_component_id, 0);
+    node.memo = memoOf(unresolved);
+    if (VNode.extractKey(unresolved)) |k| node.key = k;
+    return node;
+}
