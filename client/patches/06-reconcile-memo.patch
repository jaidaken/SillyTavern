+/// The reconcile-memo content signal from a `memo` prop, or 0 when the component carries none.
+/// Read before resolution, so it must be a value the reconciler can compare without calling the
+/// component; the app supplies a pointer-and-length hash so a sealed message stays stable and a
+/// streaming one changes every token.
+fn memoFromProps(props: anytype) u64 {
+    if (!@hasField(@TypeOf(props), "memo")) return 0;
+    return @field(props, "memo");
+}
