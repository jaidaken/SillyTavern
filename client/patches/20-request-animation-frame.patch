+/// Schedule a callback for the next animation frame. Fires once, like setTimeout, so the registry
+/// entry is a .timeout: the door delivers it as CallbackType.Timeout after requestAnimationFrame.
+pub fn requestAnimationFrame(callback: TimeoutCallback) ?u64 {
+    if (!is_wasm) return null;
+
+    const id = registerCallback(.{
+        .callback_type = .timeout,
+        .timeout_fn = callback,
+        .active = true,
+    }) orelse return null;
+
+    ext._requestAnimationFrame(id);
+    return id;
+}
