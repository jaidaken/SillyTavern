+/// Called by the door when a render throws out through the wasm frames.
+///
+/// A throw skips every Zig `defer` on the way out, including `render`'s `defer render_gate.exit()`,
+/// so the gate stays held by a pass that no longer exists and every later render is refused: the
+/// page freezes with no error of its own. Clearing the gate alone is not enough. `diffWithComponent`
+/// takes a `*VDOMTree` and reconciles IN PLACE before `applyPatches` runs, so a throw mid-apply
+/// leaves the vtree already describing a DOM that never happened; the next diff would compare vtree
+/// to vtree and never re-emit the patches that failed to land. Dropping the vtree makes the next
+/// render take the `existing_vtree == null` branch and rebuild that component from the component
+/// itself, which is the source of truth. That is a rebuild from truth, not a recovery from garbage.
+///
+/// The dirty set is deliberately kept: renders refused while the gate was stuck are still pending,
+/// and the next pass's drain owes them. Returns a count rather than a verdict: 0 = the gate was not
+/// held, 1 = gate cleared but no vtree was dropped, 2 = gate cleared and the owner's vtree dropped.
+export fn __zx_render_recover() u32 {
+    if (comptime !is_wasm) return 0;
+    if (zx.platform.role != .client) return 0;
+    if (!render_gate.in_flight) return 0;
+
+    const owner = render_gate.owner;
+    render_gate.exit();
+
+    const client = global_client orelse return 1;
+    const id = owner orelse return 1;
+    if (client.vtrees.getPtr(id)) |vtree| {
+        // Unregister BEFORE the deinit frees the nodes it walks. The rebuild's `clearContent` detaches
+        // the old DOM with a raw removeChild, so nothing else ever prunes these registrations.
+        client.unregisterVElement(vtree.vtree);
+        vtree.deinit(client.allocator);
+        _ = client.vtrees.remove(id);
+        return 2;
+    }
+    return 1;
+}
