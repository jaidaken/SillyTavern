diff --git i/src/runtime/core/render_gate.zig w/src/runtime/core/render_gate.zig
index 8622b81e..36b4c057 100644
--- i/src/runtime/core/render_gate.zig
+++ w/src/runtime/core/render_gate.zig
@@ -40,6 +40,24 @@ pub const RenderGate = struct {
         self.owner = null;
     }
 
+    /// Outcome of a recovery attempt.
+    pub const Recovered = union(enum) {
+        /// The gate was not held; the recover call was spurious and changed nothing.
+        not_held,
+        /// The gate was held and is now cleared; the payload names the pass that held it. The
+        /// dirty set is deliberately kept: renders refused while the gate was stuck are still
+        /// owed to the next pass's drain.
+        cleared: ?[]const u8,
+    };
+
+    /// Clear a gate left held by a pass that threw out through wasm (a throw skips `exit`).
+    pub fn recover(self: *RenderGate) Recovered {
+        if (!self.in_flight) return .not_held;
+        const owner = self.owner;
+        self.exit();
+        return .{ .cleared = owner };
+    }
+
     pub fn isDirty(self: *const RenderGate) bool {
         return self.dirty.count() > 0;
     }
