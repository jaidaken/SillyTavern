{
    "name": "sillytavern-tests",
    "type": "module",
    "license": "AGPL-3.0",
    "scripts": {
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.json",
        "test:smoke": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.json server-smoke",
        "test:e2e": "playwright test",
        "test:e2e:ci": "playwright test frontend/waifu-mode-autoscroll.e2e.js frontend/eventemitter.e2e.js",
        "test:e2e:waifu": "playwright test frontend/waifu-mode-autoscroll.e2e.js",
        "lint": "eslint \"**/*.js\" ./*.js",
        "lint:fix": "eslint \"**/*.js\" ./*.js --fix"
    },
    "dependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "@types/jest": "^30.0.0",
        "eslint": "^10.6.0",
        "eslint-plugin-jest": "^29.15.4",
        "eslint-plugin-playwright": "^2.10.5",
        "globals": "^17.7.0",
        "jest": "^30.4.2"
    }
}
