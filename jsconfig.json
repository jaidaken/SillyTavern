{
    "compilerOptions": {
        "module": "ESNext",
        "target": "ES2023",
        "moduleResolution": "Bundler",
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "checkJs": true,
        "noImplicitAny": false,
        "allowUmdGlobalAccess": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "strictBindCallApply": true,
        "skipLibCheck": true,
        "maxNodeModuleJsDepth": 0
    },
    "include": [
        "src/**/*.js",
        "*.js"
    ],
    "exclude": [
        "**/node_modules/**/*",
        "**/dist/**/*",
        "**/.git/**/*",
        "public/**/*",
        "backups/**/*",
        "data/**/*",
        "cache/**/*",
        "src/tokenizers/**/*",
        "docker/**/*"
    ]
}
