        "type": "git",
        "url": "https://github.com/SillyTavern/SillyTavern.git"
    },
    "version": "1.18.0",
    "scripts": {
        "init": "node src/server-init.js",
        "start": "node server.js",
        "debug": "node --inspect server.js",
        "start:global": "node server.js --global",
        "start:electron": "cd ./src/electron && npm run start",
        "start:deno": "deno run --allow-run --allow-net --allow-read --allow-write --allow-sys --allow-env server.js",
        "start:bun": "bun server.js",
        "start:no-csrf": "node server.js --disableCsrf",
        "lint": "eslint \"src/**/*.js\" \"public/**/*.js\" \"scripts/**/*.mjs\" ./*.js",
        "lint:fix": "eslint \"src/**/*.js\" \"public/**/*.js\" \"scripts/**/*.mjs\" ./*.js --fix",
        "typecheck": "node scripts/typecheck-gate.mjs",
        "typecheck:raw": "tsc --noEmit --project jsconfig.json",
        "typecheck:baseline": "node scripts/typecheck-gate.mjs --write",
        "plugins:update": "node plugins update",
        "plugins:install": "node plugins install",
        "prepare": "husky"
    },
    "bin": {
        "sillytavern": "./src/server-global.js"
    },
    "rules": {
        "no-path-concat": "off",
        "no-var": "off"
    },
    "main": "server.js",
